<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/background_cream"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Live Task Notes"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/amber_dark"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etUserName"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Enter Your Name"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_light"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join an Existing Team"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etTeamCode"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Team Code (e.g. 123456)"
            android:inputType="number"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@android:drawable/edit_text"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnJoin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Join Team"
            android:backgroundTint="@color/amber_primary"
            android:textColor="@color/white"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OR"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:textStyle="bold"
        android:textColor="@color/text_hint"/>

    <Button
        android:id="@+id/btnCreateTeam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create New Team"
        android:backgroundTint="@color/accent_orange"
        android:textColor="@color/white"
        android:padding="12dp"/>

</LinearLayout>
